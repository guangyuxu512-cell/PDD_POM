# 加密密钥（必填，用于加密敏感数据，建议使用 32 位随机字符串）
# 生成方式：python -c "import secrets; print(secrets.token_hex(16))"
ENCRYPTION_KEY=qwOg5UfnY9TU5lU5brh07AhtdLWluS1B6YEtAg_RP6M=

# 服务端口
FRONTEND_PORT=3000
BACKEND_PORT=8000

# Agent 回调地址
AGENT_CALLBACK_URL=http://localhost:8001/api/machines

# Agent 心跳配置
